<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Random UUID v4 Generator | Fast UUIDs by Browser or curl</title>
    <meta name="description" content="Generate a random UUID v4 instantly. Copy one in your browser or get a plain text UUID from the command line with curl." />
    <link rel="canonical" href="https://newuuid.net/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://newuuid.net/" />
    <meta property="og:title" content="Random UUID v4 Generator" />
    <meta property="og:description" content="Generate a random UUID v4 instantly in your browser or from the terminal with curl." />
    <meta property="og:site_name" content="newuuid.net" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Random UUID v4 Generator" />
    <meta name="twitter:description" content="Generate a random UUID v4 instantly in your browser or from the terminal with curl." />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "WebApplication",
          "name": "newuuid.net",
          "url": "https://newuuid.net/",
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "Any",
          "description": "Generate a random UUID v4 instantly in your browser or from the terminal with curl."
        }
    </script>
</head>
<body>
    <div class="page-shell">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
